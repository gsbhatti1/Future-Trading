//В ThisВ sourceВ codeВ isВ subjectВ toВ theВ termsВ ofВ theВ MozillaВ PublicВ LicenseВ 2.0В atВ https://mozilla.org/MPL/2.0/
//В В©В SeaSide420.В AnyВ timeFrame/pairВ ,В HullВ MovingВ AverageВ vsВ Candle
//@version=4
strategy("HullВ MovingВ AverageВ vsВ Candle",shorttitle="HMA-vs-Candle",overlay=true,default_qty_type=strategy.percent_of_equity,default_qty_value=100,commission_type=strategy.commission.cash_per_order,commission_value=1.00,slippage=1)
Period=input(title="HullВ MAВ Period",type=input.integer,defval=50,minval=1)
Resolution=input(title="CandleВ Resolution",В type=input.resolution,defval="D")
Price=input(title="SourceВ ofВ Price",type=input.source,defval=open)
HMA=hma(Price,Period)
Candle=security(syminfo.tickerid,Resolution,Price,barmerge.gaps_off,barmerge.lookahead_off)
change_color=HMA>Candle?color.green:color.red
plot1=plot(Candle,color=change_color,title="CandleВ Line",linewidth=2,transp=50)
plot2=plot(HMA[1],color=change_color,title="HullВ MAВ Line",linewidth=2,transp=50)
fill(plot1,plot2,color=change_color,transp=50)
strategy.close("BUY",when=Price<HMAВ andВ HMA<Candle,comment="closeВ buyВ entry")
strategy.close("SELL",when=Price>HMAВ andВ HMA>Candle,comment="closeВ sellВ entry")
ifВ (Price>HMAВ andВ HMA>CandleВ andВ Price>Price[1])
В В В В strategy.entry("BUY",strategy.long)
ifВ (Price<HMAВ andВ HMA<CandleВ andВ Price<Price[1])
В В В В strategy.entry("SELL",strategy.short)
