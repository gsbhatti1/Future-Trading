// @version=6
strategy("GB Master Ultimate Strategy v18 - ADX+MACD", overlay=true, initial_capital=100000, default_qty_type=strategy.percent_of_equity, default_qty_value=10, commission_type=strategy.commission.percent, commission_value=0.01)

// ================================================================
// GB MASTER ULTIMATE STRATEGY v18 - ADX + MACD MOMENTUM
// Built on v17: +$390.96, 48.94% WR (23/47), PF 1.404
// Target: 55%+ WR, PF 1.6+
// Changes from v17:
//   - ADX > 20 filter (only trade trending markets)
//   - MACD histogram direction confirmation
//   - 1 long + 1 short max per day (stricter gate)
//   - Candle body threshold raised: 50% (was 40%)
//   - RSI tightened: Long 54-70, Short 30-46
//   - Entry window tightened: 0950-1330 (power hours)
//   - SL uses ATR 1.0x (tighter, higher RR realized)
//   - R:R stays 2.5
// ================================================================

// === INPUTS ===
atr_len  = input.int(14,    "ATR Length",    group="Risk")
atr_sl   = input.float(1.0, "SL ATR Mult",   group="Risk")
rr       = input.float(2.5, "R:R",           group="Risk")
adx_len  = input.int(14,    "ADX Length",    group="Filter")
adx_min  = input.float(20,  "Min ADX",       group="Filter")
rsi_len  = input.int(14,    "RSI Length",    group="Filter")
mtf_tf   = input.timeframe("60", "HTF TF",   group="Trend")

// === HTF TREND (1H) ===
htf_ema21 = request.security(syminfo.tickerid, mtf_tf, ta.ema(close, 21))
htf_ema50 = request.security(syminfo.tickerid, mtf_tf, ta.ema(close, 50))
htf_bull  = htf_ema21 > htf_ema50
htf_bear  = htf_ema21 < htf_ema50

// === INDICATORS ===
ema21  = ta.ema(close, 21)
ema50  = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
rsi    = ta.rsi(close, rsi_len)
atr    = ta.atr(atr_len)
vwap   = ta.vwap(hlc3)

// ADX
[diplus, diminus, adx] = ta.dmi(adx_len, adx_len)
trending = adx > adx_min

// MACD (12, 26, 9)
[macd_line, signal_line, macd_hist] = ta.macd(close, 12, 26, 9)
macd_bull = macd_hist > macd_hist[1]  // histogram rising = bullish momentum
macd_bear = macd_hist < macd_hist[1]  // histogram falling = bearish momentum

// === SESSION FILTERS ===
entry_window = not na(time(timeframe.period, "0950-1330", "America/New_York"))
eod_exit     = not na(time(timeframe.period, "1555-1600", "America/New_York"))

// === DAILY TRADE COUNTER ===
var int long_today  = 0
var int short_today = 0
new_day = ta.change(time("D")) != 0
if new_day
    long_today  := 0
    short_today := 0

// === VWAP CROSS ===
vwap_cross_up   = close > vwap and close[1] <= vwap and close > open
vwap_cross_down = close < vwap and close[1] >= vwap and close < open
// 2-bar hold
vwap_hold_up   = vwap_cross_up   or (close > vwap and close[1] > vwap and close[2] <= vwap[2] and close > open)
vwap_hold_down = vwap_cross_down or (close < vwap and close[1] < vwap and close[2] >= vwap[2] and close < open)

// === EMA TREND ===
bull_ema = ema21 > ema50
bear_ema = ema21 < ema50

// === STRONG CANDLE FILTER (body >= 50% of range) ===
candle_range  = high - low
candle_body   = math.abs(close - open)
strong_candle = candle_range > 0 and (candle_body / candle_range) >= 0.50

// === EMA200 MACRO FILTER ===
above_ema200 = close > ema200
below_ema200 = close < ema200

// === SWING LEVELS ===
swing_lo = ta.lowest(low, 8)
swing_hi = ta.highest(high, 8)

// === ENTRY CONDITIONS v18 ===
long_conditions  = vwap_hold_up   and bull_ema and htf_bull and rsi > 54 and rsi < 70 and above_ema200 and strong_candle and trending and macd_bull
short_conditions = vwap_hold_down and bear_ema and htf_bear and rsi < 46 and rsi > 30 and below_ema200 and strong_candle and trending and macd_bear

// === ENTRY GATE (1 long + 1 short per day max) ===
long_gate  = entry_window and long_today  < 1 and strategy.position_size == 0
short_gate = entry_window and short_today < 1 and strategy.position_size == 0
long_signal  = long_conditions  and long_gate
short_signal = short_conditions and short_gate

// === TRADE EXECUTION ===
var float sl = na
var float tp = na

if long_signal
    sl   := math.min(low - atr_sl * atr, swing_lo - atr * 0.3)
    risk  = close - sl
    tp   := close + risk * rr
    if risk > 0 and sl < close and tp > close and risk < atr * 4
        strategy.entry("Long", strategy.long)
        strategy.exit("XL", "Long", stop=sl, limit=tp, comment_loss="SL", comment_profit="TP")
        long_today += 1

if short_signal
    sl   := math.max(high + atr_sl * atr, swing_hi + atr * 0.3)
    risk  = sl - close
    tp   := close - risk * rr
    if risk > 0 and sl > close and tp < close and risk < atr * 4
        strategy.entry("Short", strategy.short)
        strategy.exit("XS", "Short", stop=sl, limit=tp, comment_loss="SL", comment_profit="TP")
        short_today += 1

// === EOD EXIT ===
if eod_exit and strategy.position_size != 0
    strategy.close_all(comment="EOD")

if strategy.position_size == 0
    sl := na
    tp := na

// === WIN RATE TRACKER ===
var int   w  = 0
var float wr = 0.0
if strategy.closedtrades > strategy.closedtrades[1]
    if strategy.closedtrades.profit(strategy.closedtrades - 1) > 0
        w += 1
    wr := (w / strategy.closedtrades) * 100

// === PLOTS ===
plot(vwap,  "VWAP",    color=color.fuchsia, linewidth=2)
plot(ema21, "EMA 21",  color=color.yellow,  linewidth=1)
plot(ema50, "EMA 50",  color=color.orange,  linewidth=1)
plot(ema200,"EMA 200", color=color.white,   linewidth=2)

plotshape(long_signal,  "BUY",  style=shape.labelup,   location=location.belowbar, color=color.green, text="BUY",  textcolor=color.white, size=size.small)
plotshape(short_signal, "SELL", style=shape.labeldown, location=location.abovebar, color=color.red,   text="SELL", textcolor=color.white, size=size.small)

plot(sl, "SL", color=color.red,   style=plot.style_linebr, linewidth=2)
plot(tp, "TP", color=color.green, style=plot.style_linebr, linewidth=2)

bgcolor(htf_bull ? color.new(color.green, 94) : htf_bear ? color.new(color.red, 94) : na)
bgcolor(close > vwap ? color.new(color.green, 97) : color.new(color.red, 97))

// === DASHBOARD ===
var table d = table.new(position.top_right, 2, 10, bgcolor=color.black, border_color=color.gray, border_width=1)
if barstate.islast
    table.cell(d, 0, 0, "GB v18",   text_color=color.yellow,  text_size=size.small)
    table.cell(d, 1, 0, "ADX+MACD", text_color=color.fuchsia, text_size=size.small)
    table.cell(d, 0, 1, "HTF",      text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 1, htf_bull ? "BULL" : "BEAR", text_color=htf_bull ? color.green : color.red, text_size=size.small)
    table.cell(d, 0, 2, "EMA",      text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 2, bull_ema ? "BULL" : "BEAR", text_color=bull_ema ? color.green : color.red, text_size=size.small)
    table.cell(d, 0, 3, "EMA200",   text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 3, above_ema200 ? "ABOVE" : "BELOW", text_color=above_ema200 ? color.green : color.red, text_size=size.small)
    table.cell(d, 0, 4, "ADX",      text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 4, str.tostring(math.round(adx, 1)), text_color=adx > adx_min ? color.green : color.red, text_size=size.small)
    table.cell(d, 0, 5, "MACD",     text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 5, macd_bull ? "BULL" : "BEAR", text_color=macd_bull ? color.green : color.red, text_size=size.small)
    table.cell(d, 0, 6, "RSI",      text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 6, str.tostring(math.round(rsi, 1)), text_color=rsi > 65 ? color.red : rsi < 35 ? color.lime : color.white, text_size=size.small)
    table.cell(d, 0, 7, "Win Rate", text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 7, str.tostring(math.round(wr, 1)) + "%", text_color=wr >= 55 ? color.green : wr >= 45 ? color.yellow : color.red, text_size=size.small)
    table.cell(d, 0, 8, "Trades",   text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 8, str.tostring(strategy.closedtrades),   text_color=color.white, text_size=size.small)
    table.cell(d, 0, 9, "Net P&L",  text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 9, str.tostring(math.round(strategy.netprofit, 0)), text_color=strategy.netprofit >= 0 ? color.green : color.red, text_size=size.small)
