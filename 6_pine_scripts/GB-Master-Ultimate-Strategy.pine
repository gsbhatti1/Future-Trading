// @version=6
strategy("GB Master Ultimate Strategy v26 - MTF Confirm", overlay=true, initial_capital=100000, default_qty_type=strategy.percent_of_equity, default_qty_value=10, commission_type=strategy.commission.percent, commission_value=0.01)
// ================================================================
// GB MASTER ULTIMATE STRATEGY v26 - 15M TREND CONFIRMATION
// Results log:
// v16: +$232,    43.48% WR (20/46),  PF 1.221
// v17: +$390.96, 48.94% WR (23/47),  PF 1.404
// v18: -$433,    36.84% WR (7/19),   PF 0.3
// v19: -$149,    45.71% WR (16/35),  PF 0.817
// v20: +$176,    45.00% WR (27/60),  PF 1.131
// v21: +$393.96, 59.57% WR (28/47),  PF 1.486 <-- BEST
// v22: +$272.92, 61.70% WR (29/47),  PF 1.338  (trail too tight)
// v23: +$393.96, 59.57% WR (28/47),  PF 1.486  (3R TP = same as v21)
// v24: +$374.55, 59.57% WR (28/47),  PF 1.462  (wider trail 0.7x = worse)
// v25: +$230.41, 53.13% WR (17/32),  PF 1.354  (quality filter too tight)
// v26 changes from v21:
//   - Add 15m EMA trend confirmation (ema21>ema50 on 15m for longs)
//   - This adds meaningful multi-timeframe confluence
//   - 5m signal + 1H HTF bull + 15m trend = 3-TF alignment
//   - v21 entry conditions otherwise unchanged
// ================================================================
// === INPUTS ===
atr_len  = input.int(14,    "ATR Length",           group="Risk")
atr_sl   = input.float(1.2, "SL ATR Mult",          group="Risk")
rr       = input.float(2.5, "R:R",                  group="Risk")
trail_r  = input.float(1.0, "Trail Activate (R)",   group="Risk")
trail_atr= input.float(0.5, "Trail ATR Mult",        group="Risk")
rsi_len  = input.int(14,    "RSI Length",           group="Filter")
mtf_tf   = input.timeframe("60", "HTF TF",          group="Trend")
mtf_15   = input.timeframe("15", "MTF 15m TF",      group="Trend")
// === HTF TREND (1H) ===
htf_ema21 = request.security(syminfo.tickerid, mtf_tf, ta.ema(close, 21))
htf_ema50 = request.security(syminfo.tickerid, mtf_tf, ta.ema(close, 50))
htf_bull  = htf_ema21 > htf_ema50
htf_bear  = htf_ema21 < htf_ema50
// === 15M TREND CONFIRMATION ===
m15_ema21 = request.security(syminfo.tickerid, mtf_15, ta.ema(close, 21))
m15_ema50 = request.security(syminfo.tickerid, mtf_15, ta.ema(close, 50))
m15_bull  = m15_ema21 > m15_ema50
m15_bear  = m15_ema21 < m15_ema50
// === INDICATORS ===
ema21  = ta.ema(close, 21)
ema50  = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
rsi    = ta.rsi(close, rsi_len)
atr    = ta.atr(atr_len)
vwap   = ta.vwap(hlc3)
// === SESSION FILTERS ===
entry_window = not na(time(timeframe.period, "0945-1400", "America/New_York"))
eod_exit     = not na(time(timeframe.period, "1555-1600", "America/New_York"))
// === DAILY TRADE COUNTER ===
var int daily_trades = 0
new_day = ta.change(time("D")) != 0
if new_day
    daily_trades := 0
// === VWAP CROSS + 2-BAR HOLD ===
vwap_cross_up   = close > vwap and close[1] <= vwap and close > open
vwap_cross_down = close < vwap and close[1] >= vwap and close < open
vwap_hold_up    = vwap_cross_up   or (close > vwap and close[1] > vwap and close[2] <= vwap[2] and close > open)
vwap_hold_down  = vwap_cross_down or (close < vwap and close[1] < vwap and close[2] >= vwap[2] and close < open)
// === EMA TREND ===
bull_ema = ema21 > ema50
bear_ema = ema21 < ema50
// === STRONG CANDLE FILTER (body >= 40% of range - v21 setting) ===
candle_range  = high - low
candle_body   = math.abs(close - open)
strong_candle = candle_range > 0 and (candle_body / candle_range) >= 0.40
// === EMA200 MACRO FILTER ===
above_ema200 = close > ema200
below_ema200 = close < ema200
// === SWING LEVELS ===
swing_lo = ta.lowest(low, 8)
swing_hi = ta.highest(high, 8)
// === ENTRY CONDITIONS (v21 + 15m trend confirm) ===
long_conditions  = vwap_hold_up   and bull_ema and htf_bull and m15_bull and rsi > 52 and rsi < 72 and above_ema200 and strong_candle
short_conditions = vwap_hold_down and bear_ema and htf_bear and m15_bear and rsi < 48 and rsi > 28 and below_ema200 and strong_candle
// === ENTRY GATE ===
gate_ok      = entry_window and daily_trades < 2 and strategy.position_size == 0
long_signal  = long_conditions  and gate_ok
short_signal = short_conditions and gate_ok
// === SL/TP LEVELS ===
var float sl      = na
var float tp      = na
var float entry_p = na
var float risk_r  = na
// === ENTRIES WITH TRAILING STOP ===
if long_signal
    sl := math.min(low - atr_sl * atr, swing_lo - atr * 0.5)
    risk = close - sl
    tp := close + risk * rr
    if risk > 0 and sl < close and tp > close and risk < atr * 5
        strategy.entry("Long", strategy.long)
        strategy.exit("XL", "Long", stop=sl, limit=tp,
         trail_price  = close + risk * trail_r,
         trail_offset = trail_atr * atr / syminfo.mintick,
         comment_loss="SL", comment_profit="TP")
        entry_p := close
        risk_r  := risk
        daily_trades += 1
if short_signal
    sl := math.max(high + atr_sl * atr, swing_hi + atr * 0.5)
    risk = sl - close
    tp := close - risk * rr
    if risk > 0 and sl > close and tp < close and risk < atr * 5
        strategy.entry("Short", strategy.short)
        strategy.exit("XS", "Short", stop=sl, limit=tp,
         trail_price  = close - risk * trail_r,
         trail_offset = trail_atr * atr / syminfo.mintick,
         comment_loss="SL", comment_profit="TP")
        entry_p := close
        risk_r  := risk
        daily_trades += 1
// === EOD EXIT ===
if eod_exit and strategy.position_size != 0
    strategy.close_all(comment="EOD")
if strategy.position_size == 0
    sl      := na
    tp      := na
    entry_p := na
    risk_r  := na
// === WIN RATE TRACKER ===
var int w = 0
var float wr = 0.0
if strategy.closedtrades > strategy.closedtrades[1]
    if strategy.closedtrades.profit(strategy.closedtrades - 1) > 0
        w += 1
    wr := (w / strategy.closedtrades) * 100
// === PLOTS ===
plot(vwap, "VWAP", color=color.fuchsia, linewidth=2)
plot(ema21, "EMA 21", color=color.yellow,  linewidth=1)
plot(ema50, "EMA 50", color=color.orange,  linewidth=1)
plot(ema200,"EMA 200", color=color.white,  linewidth=2)
plotshape(long_signal,  "BUY",  style=shape.labelup,   location=location.belowbar, color=color.green, text="BUY",  textcolor=color.white, size=size.small)
plotshape(short_signal, "SELL", style=shape.labeldown, location=location.abovebar, color=color.red,   text="SELL", textcolor=color.white, size=size.small)
plot(sl, "SL", color=color.red,   style=plot.style_linebr, linewidth=2)
plot(tp, "TP", color=color.green, style=plot.style_linebr, linewidth=2)
bgcolor(htf_bull ? color.new(color.green, 94) : htf_bear ? color.new(color.red, 94) : na)
bgcolor(close > vwap ? color.new(color.green, 97) : color.new(color.red, 97))
// === DASHBOARD ===
var table d = table.new(position.top_right, 2, 10, bgcolor=color.black, border_color=color.gray, border_width=1)
if barstate.islast
    table.cell(d, 0, 0, "GB v26",      text_color=color.yellow,  text_size=size.small)
    table.cell(d, 1, 0, "MTFConfirm",  text_color=color.fuchsia, text_size=size.small)
    table.cell(d, 0, 1, "HTF 1H",      text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 1, htf_bull ? "BULL" : "BEAR", text_color=htf_bull ? color.green : color.red, text_size=size.small)
    table.cell(d, 0, 2, "MTF 15m",     text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 2, m15_bull ? "BULL" : "BEAR", text_color=m15_bull ? color.green : color.red, text_size=size.small)
    table.cell(d, 0, 3, "EMA",         text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 3, bull_ema ? "BULL" : "BEAR", text_color=bull_ema ? color.green : color.red, text_size=size.small)
    table.cell(d, 0, 4, "EMA200",      text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 4, above_ema200 ? "ABOVE" : "BELOW", text_color=above_ema200 ? color.green : color.red, text_size=size.small)
    table.cell(d, 0, 5, "VWAP",        text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 5, str.tostring(math.round(vwap, 0)), text_color=close > vwap ? color.green : color.red, text_size=size.small)
    table.cell(d, 0, 6, "RSI",         text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 6, str.tostring(math.round(rsi, 1)), text_color=rsi > 65 ? color.red : rsi < 35 ? color.lime : color.white, text_size=size.small)
    table.cell(d, 0, 7, "Win Rate",    text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 7, str.tostring(math.round(wr, 1)) + "%", text_color=wr >= 60 ? color.green : wr >= 50 ? color.yellow : color.red, text_size=size.small)
    table.cell(d, 0, 8, "Trades",      text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 8, str.tostring(strategy.closedtrades),  text_color=color.white, text_size=size.small)
    table.cell(d, 0, 9, "Net P&L",     text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 9, str.tostring(math.round(strategy.netprofit, 0)), text_color=strategy.netprofit >= 0 ? color.green : color.red, text_size=size.small)
