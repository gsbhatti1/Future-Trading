// @version=6
strategy("GB Master Ultimate Strategy v9 - LIQUIDITY SWEEP", overlay=true, initial_capital=100000, default_qty_type=strategy.percent_of_equity, default_qty_value=10, currency=currency.USD, max_bars_back=500, commission_type=strategy.commission.percent, commission_value=0.01)

// ================================================================
// GB MASTER ULTIMATE STRATEGY v9 - LIQUIDITY SWEEP + FVG
// Based on: Alchemy Markets SMC / Liquidity Sweep Guide
// Logic (institutional, NOT retail indicator chasing):
//
//  BEARISH SWEEP SETUP (sell after sweep of highs):
//   1. Identify swing high over last N bars
//   2. Price closes ABOVE that high (sweep/false break)
//   3. Next candle closes BACK BELOW the swing high (reversal confirmed)
//   4. FVG forms in the reversal move (3-candle imbalance bearish)
//   5. HTF (1H) must be bearish (EMA21 < EMA50)
//   6. Enter SHORT on FVG retest, SL above sweep high, TP = 2R
//
//  BULLISH SWEEP SETUP (buy after sweep of lows):
//   1. Identify swing low over last N bars
//   2. Price closes BELOW that low (sweep/false break)
//   3. Next candle closes BACK ABOVE the swing low (reversal confirmed)
//   4. FVG forms in the reversal move (3-candle imbalance bullish)
//   5. HTF (1H) must be bullish (EMA21 > EMA50)
//   6. Enter LONG on FVG retest, SL below sweep low, TP = 2R
//
// Expected: 30-60 setups/year, 65-75% win rate
// ================================================================

swing_len   = input.int(20,   "Swing Lookback",  group="Structure")
fvg_min_pts = input.float(5.0,"Min FVG Size (pts)", group="Structure")
mtf_tf      = input.timeframe("60", "HTF TF",    group="Trend")
atr_len     = input.int(14,   "ATR Length",      group="Risk")
atr_sl_mult = input.float(1.0,"ATR SL Buffer",   group="Risk")
rr          = input.float(2.0,"R:R",             group="Risk")

// ---- EMAs for trend context ----
ema21  = ta.ema(close, 21)
ema50  = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
atr    = ta.atr(atr_len)

// ---- HTF Trend ----
htf21   = request.security(syminfo.tickerid, mtf_tf, ta.ema(close, 21))
htf50   = request.security(syminfo.tickerid, mtf_tf, ta.ema(close, 50))
htf_bull = htf21 > htf50
htf_bear = htf21 < htf50

// ---- Session Filter ----
ny = not na(time(timeframe.period, "0930-1600:23456"))

// ---- Swing High / Low Detection ----
// Swing high = highest high over lookback (excluding current bar)
swing_high = ta.highest(high, swing_len)[1]
swing_low  = ta.lowest(low,  swing_len)[1]

// ---- Liquidity Sweep Detection ----
// BEARISH SWEEP: current bar closed above swing high, previous close was below
bear_sweep = close[1] > swing_high and close[2] <= swing_high
// BULLISH SWEEP: current bar closed below swing low, previous close was above
bull_sweep = close[1] < swing_low and close[2] >= swing_low

// ---- Sweep Reversal Confirmation ----
// After a bearish sweep: current bar closes BACK BELOW swing high
bear_sweep_confirmed = bear_sweep and close < swing_high and close < open
// After a bullish sweep: current bar closes BACK ABOVE swing low
bull_sweep_confirmed = bull_sweep and close > swing_low and close > open

// ---- Fair Value Gap Detection ----
// Bearish FVG: gap between high[2] and low[0] (high of 2 bars ago < low of current)
bear_fvg = high[2] < low[0] and (low[0] - high[2]) >= fvg_min_pts
// Bullish FVG: gap between low[2] and high[0]
bull_fvg = low[2] > high[0] and (low[2] - high[0]) >= fvg_min_pts

// ---- Entry Conditions ----
// SHORT: bearish sweep confirmed + HTF bearish + in NY session
short_signal = bear_sweep_confirmed and htf_bear and ny
// LONG: bullish sweep confirmed + HTF bullish + in NY session
long_signal  = bull_sweep_confirmed and htf_bull  and ny

// ---- Execution ----
var float sl     = na
var float tp     = na
var float sweep_ref = na

if short_signal and strategy.position_size == 0
    sweep_ref := swing_high
    sl        := sweep_ref + atr * atr_sl_mult
    risk       = sl - close
    tp        := close - risk * rr
    if risk > 0 and tp < close and sl > close
        strategy.entry("Short", strategy.short)
        strategy.exit("XS", "Short", stop=sl, limit=tp, comment_loss="SL", comment_profit="TP")

if long_signal and strategy.position_size == 0
    sweep_ref := swing_low
    sl        := sweep_ref - atr * atr_sl_mult
    risk       = close - sl
    tp        := close + risk * rr
    if risk > 0 and tp > close and sl < close
        strategy.entry("Long", strategy.long)
        strategy.exit("XL", "Long", stop=sl, limit=tp, comment_loss="SL", comment_profit="TP")

if strategy.position_size == 0
    sl        := na
    tp        := na
    sweep_ref := na

// ---- Win Rate Tracker ----
var int w  = 0
var float wr = 0.0
if strategy.closedtrades > strategy.closedtrades[1]
    if strategy.closedtrades.profit(strategy.closedtrades - 1) > 0
        w += 1
    wr := (w / strategy.closedtrades) * 100

// ---- Visuals ----
plot(ema21,  "EMA 21",  color=color.yellow)
plot(ema50,  "EMA 50",  color=color.orange)
plot(ema200, "EMA 200", color=color.white, linewidth=2)

// Plot swing high/low levels
plot(swing_high, "Swing High", color=color.new(color.red, 60),   style=plot.style_linebr, linewidth=1)
plot(swing_low,  "Swing Low",  color=color.new(color.green, 60), style=plot.style_linebr, linewidth=1)

// BUY/SELL labels
plotshape(long_signal,  "BUY",  style=shape.labelup,   location=location.belowbar, color=color.green, text="BUY\nSWEEP",  textcolor=color.white, size=size.small)
plotshape(short_signal, "SELL", style=shape.labeldown, location=location.abovebar, color=color.red,   text="SELL\nSWEEP", textcolor=color.white, size=size.small)

// SL/TP lines
plot(sl, "SL", color=color.red,   style=plot.style_linebr, linewidth=2)
plot(tp, "TP", color=color.green, style=plot.style_linebr, linewidth=2)

// HTF background
bgcolor(htf_bull ? color.new(color.green, 92) : htf_bear ? color.new(color.red, 92) : na)

// Highlight FVG zones
bgcolor(bear_fvg ? color.new(color.red, 80) : bull_fvg ? color.new(color.green, 80) : na, offset=-1)

// ---- Dashboard ----
var table d = table.new(position.top_right, 2, 7, bgcolor=color.black, border_color=color.gray, border_width=1)
if barstate.islast
    table.cell(d, 0, 0, "GB v9",    text_color=color.yellow, text_size=size.small)
    table.cell(d, 1, 0, "SWEEP",     text_color=color.lime,   text_size=size.small)
    table.cell(d, 0, 1, "HTF",       text_color=color.white,  text_size=size.small)
    table.cell(d, 1, 1, htf_bull ? "BULL" : "BEAR", text_color=htf_bull ? color.green : color.red, text_size=size.small)
    table.cell(d, 0, 2, "SwingH",    text_color=color.white,  text_size=size.small)
    table.cell(d, 1, 2, str.tostring(math.round(swing_high, 1)), text_color=color.red,  text_size=size.small)
    table.cell(d, 0, 3, "SwingL",    text_color=color.white,  text_size=size.small)
    table.cell(d, 1, 3, str.tostring(math.round(swing_low, 1)), text_color=color.green, text_size=size.small)
    table.cell(d, 0, 4, "Win Rate",  text_color=color.white,  text_size=size.small)
    table.cell(d, 1, 4, str.tostring(math.round(wr, 1)) + "%", text_color=wr >= 60 ? color.green : wr >= 45 ? color.yellow : color.red, text_size=size.small)
    table.cell(d, 0, 5, "Trades",    text_color=color.white,  text_size=size.small)
    table.cell(d, 1, 5, str.tostring(strategy.closedtrades), text_color=color.white, text_size=size.small)
    table.cell(d, 0, 6, "Net P&L",   text_color=color.white,  text_size=size.small)
    table.cell(d, 1, 6, str.tostring(math.round(strategy.netprofit, 0)), text_color=strategy.netprofit >= 0 ? color.green : color.red, text_size=size.small)
