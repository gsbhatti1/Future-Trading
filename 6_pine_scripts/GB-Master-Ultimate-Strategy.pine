// @version=6
strategy("GB Master Ultimate Strategy v15 - PRECISION HTF", overlay=true, initial_capital=100000, default_qty_type=strategy.percent_of_equity, default_qty_value=10, commission_type=strategy.commission.percent, commission_value=0.01)

// ================================================================
// GB MASTER ULTIMATE STRATEGY v15 - HIGH PRECISION MULTI-TF
// Entry criteria (ALL must align):
//  1. 4H EMA21 > EMA50 > EMA200 (strong bull) + 1H EMA21 > EMA50
//  2. Price pulled back to 5m EMA21 zone (within 0.2%)
//  3. RSI crossed above 50 THIS BAR (momentum initiation)
//  4. MACD histogram positive
//  5. Candle body > 50% of range (strong candle)
//  6. NY session 9:45 AM - 12:00 PM only
//  7. Max 2 trades per week
//  8. SL: swing low - 1x ATR, TP: 3R
// ================================================================

// ---- Inputs ----
mtf_4h  = input.timeframe("240", "4H TF",  group="Trend")
mtf_1h  = input.timeframe("60",  "1H TF",  group="Trend")
rsi_len = input.int(14,   "RSI Length",     group="Filter")
atr_len = input.int(14,   "ATR Length",     group="Risk")
atr_sl  = input.float(1.0, "SL ATR Mult",  group="Risk")
rr      = input.float(3.0, "R:R",           group="Risk")

// ---- MTF Trend ----
f_ema21_4h  = request.security(syminfo.tickerid, mtf_4h, ta.ema(close, 21))
f_ema50_4h  = request.security(syminfo.tickerid, mtf_4h, ta.ema(close, 50))
f_ema200_4h = request.security(syminfo.tickerid, mtf_4h, ta.ema(close, 200))
f_ema21_1h  = request.security(syminfo.tickerid, mtf_1h, ta.ema(close, 21))
f_ema50_1h  = request.security(syminfo.tickerid, mtf_1h, ta.ema(close, 50))

bull_4h = f_ema21_4h > f_ema50_4h and f_ema50_4h > f_ema200_4h
bear_4h = f_ema21_4h < f_ema50_4h and f_ema50_4h < f_ema200_4h
bull_1h = f_ema21_1h > f_ema50_1h
bear_1h = f_ema21_1h < f_ema50_1h
strong_bull = bull_4h and bull_1h
strong_bear = bear_4h and bear_1h

// ---- Local 5m Indicators ----
ema9   = ta.ema(close, 9)
ema21  = ta.ema(close, 21)
ema50  = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
rsi    = ta.rsi(close, rsi_len)
atr    = ta.atr(atr_len)
[macd_l, macd_s, macd_h] = ta.macd(close, 12, 26, 9)

// ---- Signal Components ----
rsi_cross_up   = rsi > 50 and rsi[1] <= 50
rsi_cross_down = rsi < 50 and rsi[1] >= 50
body_sz  = math.abs(close - open)
rng_sz   = high - low
body_pct = rng_sz > 0 ? body_sz / rng_sz : 0
qual_bull = close > open and body_pct > 0.5
qual_bear = close < open and body_pct > 0.5
near21_bull = low <= ema21 * 1.002 and close > ema21 and close > open
near21_bear = high >= ema21 * 0.998 and close < ema21 and close < open

// ---- Session ----
entry_session = not na(time(timeframe.period, "0945-1200", "America/New_York"))
eod_exit      = not na(time(timeframe.period, "1555-1600", "America/New_York"))

// ---- Weekly Trade Limit ----
var int week_trades = 0
var int last_week   = 0
cur_week = weekofyear(time)
if cur_week != last_week
    week_trades := 0
    last_week   := cur_week

// ---- Entry Conditions ----
long_conditions  = strong_bull and near21_bull and rsi_cross_up and macd_h > 0 and qual_bull
short_conditions = strong_bear and near21_bear and rsi_cross_down and macd_h < 0 and qual_bear
session_ok = entry_session and week_trades < 2 and strategy.position_size == 0

long_signal  = long_conditions  and session_ok
short_signal = short_conditions and session_ok

// ---- SL / TP ----
swing_lo = ta.lowest(low, 10)
swing_hi = ta.highest(high, 10)
var float sl = na
var float tp = na

if long_signal
    sl := swing_lo - atr_sl * atr
    risk = close - sl
    tp := close + risk * rr
    if risk > 0 and sl < close and tp > close and risk < atr * 5
        strategy.entry("Long", strategy.long)
        strategy.exit("XL", "Long", stop=sl, limit=tp, comment_loss="SL", comment_profit="TP")
        week_trades += 1

if short_signal
    sl := swing_hi + atr_sl * atr
    risk = sl - close
    tp := close - risk * rr
    if risk > 0 and sl > close and tp < close and risk < atr * 5
        strategy.entry("Short", strategy.short)
        strategy.exit("XS", "Short", stop=sl, limit=tp, comment_loss="SL", comment_profit="TP")
        week_trades += 1

if eod_exit and strategy.position_size != 0
    strategy.close_all(comment="EOD")

if strategy.position_size == 0
    sl := na
    tp := na

// ---- Win Rate ----
var int w = 0
var float wr = 0.0
if strategy.closedtrades > strategy.closedtrades[1]
    if strategy.closedtrades.profit(strategy.closedtrades - 1) > 0
        w += 1
    wr := (w / strategy.closedtrades) * 100

// ---- Visuals ----
plot(ema9,   "EMA 9",   color=color.aqua,   linewidth=1)
plot(ema21,  "EMA 21",  color=color.yellow, linewidth=1)
plot(ema50,  "EMA 50",  color=color.orange, linewidth=1)
plot(ema200, "EMA 200", color=color.white,  linewidth=2)
plotshape(long_signal,  "BUY",  style=shape.labelup,   location=location.belowbar, color=color.green, text="BUY",  textcolor=color.white, size=size.normal)
plotshape(short_signal, "SELL", style=shape.labeldown, location=location.abovebar, color=color.red,   text="SELL", textcolor=color.white, size=size.normal)
plot(sl, "SL", color=color.red,   style=plot.style_linebr, linewidth=2)
plot(tp, "TP", color=color.green, style=plot.style_linebr, linewidth=2)
bgcolor(strong_bull ? color.new(color.green, 94) : strong_bear ? color.new(color.red, 94) : na)

// ---- Dashboard ----
var table d = table.new(position.top_right, 2, 8, bgcolor=color.black, border_color=color.gray, border_width=1)
if barstate.islast
    table.cell(d, 0, 0, "GB v15",   text_color=color.yellow, text_size=size.small)
    table.cell(d, 1, 0, "PREC",     text_color=color.lime,   text_size=size.small)
    table.cell(d, 0, 1, "4H",       text_color=color.white,  text_size=size.small)
    table.cell(d, 1, 1, bull_4h ? "BULL" : bear_4h ? "BEAR" : "CHOP", text_color=bull_4h ? color.green : bear_4h ? color.red : color.gray, text_size=size.small)
    table.cell(d, 0, 2, "1H",       text_color=color.white,  text_size=size.small)
    table.cell(d, 1, 2, bull_1h ? "BULL" : "BEAR", text_color=bull_1h ? color.green : color.red, text_size=size.small)
    table.cell(d, 0, 3, "RSI",      text_color=color.white,  text_size=size.small)
    table.cell(d, 1, 3, str.tostring(math.round(rsi, 1)), text_color=rsi > 65 ? color.red : rsi < 35 ? color.lime : color.white, text_size=size.small)
    table.cell(d, 0, 4, "Session",  text_color=color.white,  text_size=size.small)
    table.cell(d, 1, 4, entry_session ? "ACTIVE" : "OFF", text_color=entry_session ? color.green : color.gray, text_size=size.small)
    table.cell(d, 0, 5, "Win Rate", text_color=color.white,  text_size=size.small)
    table.cell(d, 1, 5, str.tostring(math.round(wr, 1)) + "%", text_color=wr >= 60 ? color.green : wr >= 45 ? color.yellow : color.red, text_size=size.small)
    table.cell(d, 0, 6, "Trades",   text_color=color.white,  text_size=size.small)
    table.cell(d, 1, 6, str.tostring(strategy.closedtrades), text_color=color.white, text_size=size.small)
    table.cell(d, 0, 7, "Net P&L",  text_color=color.white,  text_size=size.small)
    table.cell(d, 1, 7, str.tostring(math.round(strategy.netprofit, 0)), text_color=strategy.netprofit >= 0 ? color.green : color.red, text_size=size.small)
