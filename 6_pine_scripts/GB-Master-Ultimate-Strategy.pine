// @version=6
strategy("GB Master Ultimate Strategy v2", overlay=true, initial_capital=100000, default_qty_type=strategy.percent_of_equity, default_qty_value=10, currency=currency.USD)

// This strategy is a consolidated "best-of-breed" system based on 1000+ Chinese strategies.
// It combines Multi-Timeframe Breakout logic, EMA Trend following, MACD Momentum, and SuperTrend Risk Management.

// --- INPUTS ---
ema_fast_len = input.int(21, "EMA Fast Length")
ema_slow_len = input.int(50, "EMA Slow Length")
macd_fast = input.int(12, "MACD Fast")
macd_slow = input.int(26, "MACD Slow")
macd_signal = input.int(9, "MACD Signal")
st_atr_len = input.int(10, "SuperTrend ATR Length")
st_mult = input.float(3.0, "SuperTrend Multiplier")
risk_reward_ratio = input.float(3.0, "Risk:Reward Ratio")

// --- CALCULATIONS ---
ema_fast = ta.ema(close, ema_fast_len)
ema_slow = ta.ema(close, ema_slow_len)
[macd_line, signal_line, _] = ta.macd(close, macd_fast, macd_slow, macd_signal)
[supertrend, direction] = ta.supertrend(st_mult, st_atr_len)

// Multi-Timeframe synergy (from strategy 5 logic)
fifteenHigh = request.security(syminfo.tickerid, "15", high)
fifteenLow = request.security(syminfo.tickerid, "15", low)
var float last15High = na
var float last15Low = na
new15bar = ta.change(time("15"))
if new15bar
    last15High := fifteenHigh[1]
    last15Low := fifteenLow[1]

// --- SIGNALS ---
// Long: Price > 15m high AND EMA cross AND MACD bullish AND SuperTrend green
long_condition = close > last15High and ta.crossover(ema_fast, ema_slow) and macd_line > signal_line and direction < 0

// Short: Price < 15m low AND EMA cross AND MACD bearish AND SuperTrend red
short_condition = close < last15Low and ta.crossunder(ema_fast, ema_slow) and macd_line < signal_line and direction > 0

// --- EXECUTION ---
if (long_condition)
    float stopLoss = last15Low
    float risk = close - stopLoss
    float takeProfit = close + (risk * risk_reward_ratio)
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop=stopLoss, limit=takeProfit)

if (short_condition)
    float stopLoss = last15High
    float risk = stopLoss - close
    float takeProfit = close - (risk * risk_reward_ratio)
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop=stopLoss, limit=takeProfit)

// --- PLOTS ---
plot(ema_fast, color=color.blue, title="EMA Fast")
plot(ema_slow, color=color.red, title="EMA Slow")
plot(supertrend, color=direction < 0 ? color.green : color.red, title="SuperTrend")
plot(last15High, "15m High", color=color.gray, style=plot.style_stepline)
plot(last15Low, "15m Low", color=color.gray, style=plot.style_stepline)
