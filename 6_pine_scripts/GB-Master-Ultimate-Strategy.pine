// @version=6
strategy("GB Master Ultimate Strategy v16 - VWAP", overlay=true, initial_capital=100000, default_qty_type=strategy.percent_of_equity, default_qty_value=10, commission_type=strategy.commission.percent, commission_value=0.01)

// ================================================================
// GB MASTER ULTIMATE STRATEGY v16 - VWAP RECLAIM (FIRST PROFITABLE)
// Status: +$232, 43.48% WR (20/46), Profit Factor 1.221
// Professional VWAP + EMA trend following for NAS100 5m
// Logic:
//  LONG: Price crosses ABOVE VWAP + EMA21>EMA50 + HTF bull + RSI>50
//  SHORT: Price crosses BELOW VWAP + EMA21<EMA50 + HTF bear + RSI<50
//  SL: 1.5x ATR, TP: 2R
//  Max 3 trades per day, NY session only
// ================================================================

atr_len  = input.int(14,   "ATR Length",   group="Risk")
atr_sl   = input.float(1.5,"SL ATR Mult",  group="Risk")
rr       = input.float(2.0, "R:R",          group="Risk")
rsi_len  = input.int(14,   "RSI Length",   group="Filter")
mtf_tf   = input.timeframe("60", "HTF TF", group="Trend")

htf_ema21 = request.security(syminfo.tickerid, mtf_tf, ta.ema(close, 21))
htf_ema50 = request.security(syminfo.tickerid, mtf_tf, ta.ema(close, 50))
htf_bull  = htf_ema21 > htf_ema50
htf_bear  = htf_ema21 < htf_ema50

ema21  = ta.ema(close, 21)
ema50  = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
rsi    = ta.rsi(close, rsi_len)
atr    = ta.atr(atr_len)
vwap   = ta.vwap(hlc3)

ny_session   = not na(time(timeframe.period, "0930-1600", "America/New_York"))
entry_window = not na(time(timeframe.period, "0945-1400", "America/New_York"))
eod_exit     = not na(time(timeframe.period, "1555-1600", "America/New_York"))

var int daily_trades = 0
new_day = ta.change(time("D")) != 0
if new_day
    daily_trades := 0

vwap_cross_up   = close > vwap and close[1] <= vwap and close > open
vwap_cross_down = close < vwap and close[1] >= vwap and close < open
bull_ema = ema21 > ema50
bear_ema = ema21 < ema50

long_conditions  = vwap_cross_up   and bull_ema and htf_bull and rsi > 50 and rsi < 75
short_conditions = vwap_cross_down and bear_ema and htf_bear and rsi < 50 and rsi > 25
gate_ok = entry_window and daily_trades < 3 and strategy.position_size == 0

long_signal  = long_conditions  and gate_ok
short_signal = short_conditions and gate_ok

swing_lo = ta.lowest(low, 8)
swing_hi = ta.highest(high, 8)
var float sl = na
var float tp = na

if long_signal
    sl := math.min(low - atr_sl * atr, swing_lo - atr * 0.5)
    risk = close - sl
    tp := close + risk * rr
    if risk > 0 and sl < close and tp > close and risk < atr * 6
        strategy.entry("Long", strategy.long)
        strategy.exit("XL", "Long", stop=sl, limit=tp, comment_loss="SL", comment_profit="TP")
        daily_trades += 1

if short_signal
    sl := math.max(high + atr_sl * atr, swing_hi + atr * 0.5)
    risk = sl - close
    tp := close - risk * rr
    if risk > 0 and sl > close and tp < close and risk < atr * 6
        strategy.entry("Short", strategy.short)
        strategy.exit("XS", "Short", stop=sl, limit=tp, comment_loss="SL", comment_profit="TP")
        daily_trades += 1

if eod_exit and strategy.position_size != 0
    strategy.close_all(comment="EOD")

if strategy.position_size == 0
    sl := na
    tp := na

var int w = 0
var float wr = 0.0
if strategy.closedtrades > strategy.closedtrades[1]
    if strategy.closedtrades.profit(strategy.closedtrades - 1) > 0
        w += 1
    wr := (w / strategy.closedtrades) * 100

plot(vwap,  "VWAP",   color=color.fuchsia, linewidth=2)
plot(ema21, "EMA 21", color=color.yellow,  linewidth=1)
plot(ema50, "EMA 50", color=color.orange,  linewidth=1)
plot(ema200,"EMA 200",color=color.white,   linewidth=2)
plotshape(long_signal,  "BUY",  style=shape.labelup,   location=location.belowbar, color=color.green, text="BUY",  textcolor=color.white, size=size.small)
plotshape(short_signal, "SELL", style=shape.labeldown, location=location.abovebar, color=color.red,   text="SELL", textcolor=color.white, size=size.small)
plot(sl, "SL", color=color.red,   style=plot.style_linebr, linewidth=2)
plot(tp, "TP", color=color.green, style=plot.style_linebr, linewidth=2)
bgcolor(htf_bull ? color.new(color.green, 94) : htf_bear ? color.new(color.red, 94) : na)
bgcolor(close > vwap ? color.new(color.green, 97) : color.new(color.red, 97))

var table d = table.new(position.top_right, 2, 8, bgcolor=color.black, border_color=color.gray, border_width=1)
if barstate.islast
    table.cell(d, 0, 0, "GB v16",   text_color=color.yellow,  text_size=size.small)
    table.cell(d, 1, 0, "VWAP",     text_color=color.fuchsia, text_size=size.small)
    table.cell(d, 0, 1, "HTF",      text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 1, htf_bull ? "BULL" : "BEAR", text_color=htf_bull ? color.green : color.red, text_size=size.small)
    table.cell(d, 0, 2, "EMA",      text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 2, bull_ema ? "BULL" : "BEAR", text_color=bull_ema ? color.green : color.red, text_size=size.small)
    table.cell(d, 0, 3, "VWAP",     text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 3, str.tostring(math.round(vwap, 0)), text_color=close > vwap ? color.green : color.red, text_size=size.small)
    table.cell(d, 0, 4, "RSI",      text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 4, str.tostring(math.round(rsi, 1)), text_color=rsi > 65 ? color.red : rsi < 35 ? color.lime : color.white, text_size=size.small)
    table.cell(d, 0, 5, "Win Rate", text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 5, str.tostring(math.round(wr, 1)) + "%", text_color=wr >= 60 ? color.green : wr >= 45 ? color.yellow : color.red, text_size=size.small)
    table.cell(d, 0, 6, "Trades",   text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 6, str.tostring(strategy.closedtrades),  text_color=color.white, text_size=size.small)
    table.cell(d, 0, 7, "Net P&L",  text_color=color.white,   text_size=size.small)
    table.cell(d, 1, 7, str.tostring(math.round(strategy.netprofit, 0)), text_color=strategy.netprofit >= 0 ? color.green : color.red, text_size=size.small)
