// @version=6
strategy("GB Master Ultimate Strategy v5 - PULLBACK PRO", overlay=true, initial_capital=100000, default_qty_type=strategy.percent_of_equity, default_qty_value=10, currency=currency.USD, max_bars_back=500, commission_type=strategy.commission.percent, commission_value=0.01)

// ================================================================
// GB MASTER ULTIMATE STRATEGY v5
// Goal: Fix low win rate by switching to Pullback logic.
// Logic: Higher TF Trend Filter + Pullback to EMA + Structure SL
// Optimized for: NAS100, US30 (5m / 15m)
// ================================================================

// ---- INPUTS ----
ema_fast_len  = input.int(20,  "Fast EMA",       group="Trend")
ema_slow_len  = input.int(50,  "Slow EMA",       group="Trend")
ema_trend_len = input.int(200, "Trend Filter",   group="Trend")
mtf_tf        = input.timeframe("60", "Trend TF", group="Trend")

rsi_len       = input.int(14,  "RSI Length",     group="Pullback")
rsi_low       = input.int(45,  "RSI Buy Pullback", group="Pullback")
rsi_high      = input.int(55,  "RSI Sell Pullback",group="Pullback")

atr_len       = input.int(14,  "ATR Length",     group="Risk")
atr_sl_mult   = input.float(1.5, "ATR SL Mult",  group="Risk")
rr_ratio      = input.float(2.0, "Reward:Risk",  group="Risk")

// ---- CALCULATIONS ----
ema_fast  = ta.ema(close, ema_fast_len)
ema_slow  = ta.ema(close, ema_slow_len)
ema_trend = ta.ema(close, ema_trend_len)
rsi_val   = ta.rsi(close, rsi_len)
atr_val   = ta.atr(atr_len)

// Higher Timeframe Trend
htf_ema_fast = request.security(syminfo.tickerid, mtf_tf, ta.ema(close, 20))
htf_ema_slow = request.security(syminfo.tickerid, mtf_tf, ta.ema(close, 50))
htf_bullish  = htf_ema_fast > htf_ema_slow
htf_bearish  = htf_ema_fast < htf_ema_slow

// Session Filter (NY Open to Lunch)
ny_session = not na(time(timeframe.period, "0930-1400:23456"))

// ---- PULLBACK LOGIC ----
// LONG: HTF Trend is UP + Price above EMA 200 + RSI pulls back below 45 + Price crosses above EMA 20
long_pullback = htf_bullish and close > ema_trend and rsi_val < rsi_low and ta.crossover(close, ema_fast) and ny_session

// SHORT: HTF Trend is DOWN + Price below EMA 200 + RSI pulls back above 55 + Price crosses below EMA 20
short_pullback = htf_bearish and close < ema_trend and rsi_val > rsi_high and ta.crossunder(close, ema_fast) and ny_session

// ---- EXECUTION ----
var float sl = na
var float tp = na
var float ep = na

if long_pullback and strategy.position_size == 0
    ep := close
    sl := ta.lowest(low, 5) - (atr_val * 0.5) // Swing Low SL
    risk = ep - sl
    tp := ep + (risk * rr_ratio)
    if tp > ep and sl < ep
        strategy.entry("Long", strategy.long)
        strategy.exit("Exit", "Long", stop=sl, limit=tp, comment_loss="SL", comment_profit="TP")

if short_pullback and strategy.position_size == 0
    ep := close
    sl := ta.highest(high, 5) + (atr_val * 0.5) // Swing High SL
    risk = sl - ep
    tp := ep - (risk * rr_ratio)
    if tp < ep and sl > ep
        strategy.entry("Short", strategy.short)
        strategy.exit("Exit", "Short", stop=sl, limit=tp, comment_loss="SL", comment_profit="TP")

if strategy.position_size == 0
    sl := na
    tp := na
    ep := na

// ---- VISUALS ----
plot(ema_fast,  "EMA 20",  color=color.yellow)
plot(ema_slow,  "EMA 50",  color=color.orange)
plot(ema_trend, "EMA 200", color=color.white, linewidth=2)

plotshape(long_pullback,  "BUY",  style=shape.labelup,   location=location.belowbar, color=color.green, text="BUY",  textcolor=color.white)
plotshape(short_pullback, "SELL", style=shape.labeldown, location=location.abovebar, color=color.red,   text="SELL", textcolor=color.white)

plot(sl, "SL", color=color.red,  style=plot.style_linebr, linewidth=2)
plot(tp, "TP", color=color.green, style=plot.style_linebr, linewidth=2)

// Trend BG
bgcolor(htf_bullish ? color.new(color.green, 90) : htf_bearish ? color.new(color.red, 90) : na)

// Dashboard
var table d = table.new(position.top_right, 2, 5, bgcolor=color.black, border_color=color.gray, border_width=1)
if barstate.islast
    table.cell(d, 0, 0, "GB PULLBACK v5", text_color=color.yellow)
    table.cell(d, 0, 1, "HTF Trend",     text_color=color.white)
    table.cell(d, 1, 1, htf_bullish ? "BULL" : "BEAR", text_color=htf_bullish ? color.green : color.red)
    table.cell(d, 0, 2, "Win Rate (Sim)", text_color=color.white)
    table.cell(d, 1, 2, str.tostring(math.round(strategy.winrate, 1)) + "%", text_color=color.white)
    table.cell(d, 0, 3, "Total Trades",  text_color=color.white)
    table.cell(d, 1, 3, str.tostring(strategy.closedtrades), text_color=color.white)
    table.cell(d, 0, 4, "Net Profit",    text_color=color.white)
    table.cell(d, 1, 4, str.tostring(math.round(strategy.netprofit, 2)), text_color=strategy.netprofit >= 0 ? color.green : color.red)
