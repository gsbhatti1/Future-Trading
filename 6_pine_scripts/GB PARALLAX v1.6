alertcondition(nyJustReady and ny.entryDir == -1, "NY PARALLAX Short", '{"signal":"PARALLAX","session":"NY","action":"sell","symbol":"{{ticker}}","price":{{close}}}')
alertcondition(lonJustReady and lon.entryDir == 1, "LON PARALLAX Long", '{"signal":"PARALLAX","session":"LON","action":"buy","symbol":"{{ticker}}","price":{{close}}}')
alertcondition(lonJustReady and lon.entryDir == -1, "LON PARALLAX Short", '{"signal":"PARALLAX","session":"LON","action":"sell","symbol":"{{ticker}}","price":{{close}}}')
