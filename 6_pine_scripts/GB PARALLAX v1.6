hudPos       = input.string("Top Right", title = "HUD Position",
    options = ["Top Right","Top Left","Bottom Right","Bottom Left"], group = "⑩ HUD")

pdhColor = input.color(#00BFFF, title = "PDH", group = "⑪ Colors", inline = "c1")
pdlColor = input.color(#FF6347, title = "PDL", group = "⑪ Colors", inline = "c1")
pwhColor = input.color(#9370DB, title = "PWH", group = "⑪ Colors", inline = "c2")
pwlColor = input.color(#DA70D6, title = "PWL", group = "⑪ Colors", inline = "c2")
pmhColor = input.color(#FFA500, title = "PMH", group = "⑪ Colors", inline = "c3")
pmlColor = input.color(#FF8C00, title = "PML", group = "⑪ Colors", inline = "c3")
