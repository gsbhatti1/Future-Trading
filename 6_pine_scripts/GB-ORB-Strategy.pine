// @version=6
// ================================================================
// GB ORB STRATEGY v4 — Opening Range Breakout (Video Match)
// Based on: TradeXLabs video - 75% win rate, 886 trades on NQ 5m
// Key fixes v4: EOD force-close, EMA200 trend filter, clean session
// Logic: NY open range (9:30 to 9:30+N mins) -> breakout entry
// SL = opposite side of ORB. TP = RR x risk. Close by 15:30 NY.
// ================================================================
strategy("GB ORB Strategy v4 - Scalping",
     overlay=true, initial_capital=50000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=10,
     commission_type=strategy.commission.percent,
     commission_value=0.01,
     max_bars_back=500)

// ---- INPUTS ----
orb_len     = input.int(30,  "ORB Length (mins)",  minval=5, maxval=60, group="ORB")
rr          = input.float(1.0, "Reward:Risk",       minval=0.5, step=0.25, group="ORB")
use_long    = input.bool(true,  "Long Trades",  group="ORB")
use_short   = input.bool(true,  "Short Trades", group="ORB")
one_per_day = input.bool(true,  "1 Trade/Day",  group="ORB")
use_trend   = input.bool(true,  "Trend Filter (EMA200)", group="Filter")
eod_close   = input.bool(true,  "Force Close 15:30 NY",  group="Filter")

// ---- NY TIME ----
h          = hour(time,   "America/New_York")
m          = minute(time, "America/New_York")
dow        = dayofweek(time, "America/New_York")
is_weekday = dow >= 2 and dow <= 6

// Time zones
in_orb    = is_weekday and h == 9 and m >= 30 and m < (30 + orb_len)
after_orb = is_weekday and (h > 9 or (h == 9 and m >= (30 + orb_len)))
ny_open   = is_weekday and h >= 9 and h < 16
eod_now   = is_weekday and h == 15 and m >= 30

// ---- ORB RANGE ----
var float orb_hi  = na
var float orb_lo  = na
var bool  locked  = false
var bool  traded  = false
var int   prev_day = na

cur_day    = dayofmonth(time, "America/New_York")
is_new_day = cur_day != prev_day and is_weekday

if is_new_day
    prev_day := cur_day
    orb_hi   := na
    orb_lo   := na
    locked   := false
    traded   := false

if in_orb
    orb_hi := na(orb_hi) ? high : math.max(orb_hi, high)
    orb_lo := na(orb_lo) ? low  : math.min(orb_lo, low)

if after_orb and not na(orb_hi) and not locked
    locked := true

// ---- TREND FILTER ----
ema200     = ta.ema(close, 200)
bull_trend = close > ema200
bear_trend = close < ema200

// ---- SIGNALS ----
can_trade = locked and ny_open and strategy.position_size == 0
if one_per_day
    can_trade := can_trade and not traded

long_ok   = not use_trend or bull_trend
short_ok  = not use_trend or bear_trend

long_sig  = can_trade and use_long  and long_ok  and ta.crossover(close,  orb_hi)
short_sig = can_trade and use_short and short_ok and ta.crossunder(close, orb_lo)

// ---- EXECUTE ----
if long_sig
    risk_pts = close - orb_lo
    if risk_pts > 0
        strategy.entry("Long", strategy.long)
        strategy.exit("Long X", "Long",
             stop=orb_lo, limit=close + risk_pts * rr,
             comment_loss="SL", comment_profit="TP")
        traded := true

if short_sig
    risk_pts = orb_hi - close
    if risk_pts > 0
        strategy.entry("Short", strategy.short)
        strategy.exit("Short X", "Short",
             stop=orb_hi, limit=close - risk_pts * rr,
             comment_loss="SL", comment_profit="TP")
        traded := true

// Force close end of day
if eod_close and eod_now and strategy.position_size != 0
    strategy.close_all(comment="EOD")

// ---- VISUALS ----
plot(locked or in_orb ? orb_hi : na, "ORB High",
     color=color.new(color.lime, 0), linewidth=2, style=plot.style_linebr)
plot(locked or in_orb ? orb_lo : na, "ORB Low",
     color=color.new(color.red, 0),  linewidth=2, style=plot.style_linebr)
plot(use_trend ? ema200 : na, "EMA 200", color=color.white, linewidth=1)

bgcolor(in_orb    ? color.new(color.yellow, 88) : na, title="ORB Build")
bgcolor(long_sig  ? color.new(color.green,  75) : na, title="Long Break")
bgcolor(short_sig ? color.new(color.red,    75) : na, title="Short Break")

plotshape(long_sig,  "LONG",  style=shape.labelup,   location=location.belowbar,
     color=color.green, text="ORB\nLONG",  textcolor=color.white, size=size.small)
plotshape(short_sig, "SHORT", style=shape.labeldown, location=location.abovebar,
     color=color.red,   text="ORB\nSHORT", textcolor=color.white, size=size.small)

// ---- WIN RATE TRACKER ----
var int wins = 0
var int tots = 0
tc = strategy.closedtrades != strategy.closedtrades[1]
if tc
    tots := strategy.closedtrades
    if strategy.closedtrades.profit(strategy.closedtrades - 1) > 0
        wins += 1
wr = tots > 0 ? (wins / tots) * 100 : 0.0

// ---- DASHBOARD ----
var table dash = table.new(position.top_right, 2, 6,
     bgcolor=color.rgb(5,5,5), border_color=color.gray, border_width=1)
if barstate.islast
    table.cell(dash, 0, 0, "GB ORB v4",  text_color=color.yellow, text_size=size.small)
    table.cell(dash, 1, 0, "SCALPING",   text_color=color.lime,   text_size=size.small)
    table.cell(dash, 0, 1, "Win Rate",   text_color=color.white,  text_size=size.small)
    table.cell(dash, 1, 1, str.tostring(math.round(wr, 1)) + "%",
         text_color=wr >= 65 ? color.lime : color.orange, text_size=size.small)
    table.cell(dash, 0, 2, "Trades",     text_color=color.white,  text_size=size.small)
    table.cell(dash, 1, 2, str.tostring(strategy.closedtrades),   text_color=color.white, text_size=size.small)
    table.cell(dash, 0, 3, "Net P&L",    text_color=color.white,  text_size=size.small)
    table.cell(dash, 1, 3, "$" + str.tostring(math.round(strategy.netprofit, 0)),
         text_color=strategy.netprofit >= 0 ? color.lime : color.red, text_size=size.small)
    table.cell(dash, 0, 4, "Profit Fac", text_color=color.white,  text_size=size.small)
    table.cell(dash, 1, 4, str.tostring(math.round(strategy.grossprofit / math.max(math.abs(strategy.grossloss), 1), 2)),
         text_color=color.white, text_size=size.small)
    table.cell(dash, 0, 5, "ORB Range",  text_color=color.white,  text_size=size.small)
    table.cell(dash, 1, 5, locked ? str.tostring(math.round(orb_hi - orb_lo, 1)) + " pts" : "Building...",
         text_color=color.aqua, text_size=size.small)
