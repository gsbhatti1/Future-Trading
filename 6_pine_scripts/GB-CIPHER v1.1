alertcondition(bosNow and bosDir == 1, "Bullish BOS", "CIPHER: BOS ▲")
alertcondition(bosNow and bosDir == -1, "Bearish BOS", "CIPHER: BOS ▼")
alertcondition(chochNow and chochDir == 1, "Bullish ChoCh", "CIPHER: ChoCh ▲")
alertcondition(chochNow and chochDir == -1, "Bearish ChoCh", "CIPHER: ChoCh ▼")
alertcondition(bullEntry, "CIPHER Long Entry", "CIPHER: ✓ LONG entry signal")
alertcondition(bearEntry, "CIPHER Short Entry", "CIPHER: ✓ SHORT entry signal")

